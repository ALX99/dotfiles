{
  "name": "Arch Linux Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "codespace",
  "containerEnv": {
    "EDITOR": "nvim",
    "VISUAL": "nvim",
    "SHELL": "/bin/bash"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    },
    "codespaces": {
      "repositories": {
        "alx99/sail": {
          "permissions": {
            "contents": "write"
          }
        },
        "alx99/muninn": {
          "permissions": {
            "contents": "write"
          }
        }
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/bootstrap.sh"
}
