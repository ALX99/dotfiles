{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "language": "japanese",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Skill",
      "WebSearch",
      "WebFetch",
      "Read(~/go/**)",
      "Read(//tmp/**)",
      "Edit(//tmp/**)",
      "Read(~/projects/**)",
      "Read(~/dotfiles/**)",
      "Edit(~/projects/**)",
      "Write(~/projects/**)",
      "Read(~/.claude/**)",
      "Bash(cd:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(make:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(go:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(kustomize:*)",
      "Bash(kubectl:*)",
      "Bash(gh pr:*)",
      "Bash(gh * view)",
      "mcp__gopls__*",
      "mcp__chrome-devtools__*",
      "mcp__svelte__*"
    ],
    "deny": [
      "Bash(find:*)",
      "Bash(grep:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/var/folders/"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "^(?!AskUserQuestion$|ExitPlanMode$).*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/claude-permission-dialog"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command') && if echo \"$cmd\" | grep -qE '\\brm\\b|\\brmdir\\b|\\bshred\\b|\\bunlink\\b|\\btruncate\\b|\\bdel\\b|\\bdelete\\b|\\bremove\\b'; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Destructive command blocked\"}}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".go\")) | select(endswith(\"gen.go\") | not)' | xargs -r gofmt -w"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[[ $(uname -s) == 'Darwin' ]] && { cwd=$(jq -r '.cwd // \".\"'); dir=$(basename \"$cwd\"); osascript -e \"display notification \\\"Waiting for input in: $dir\\\" with title \\\"Claude Code\\\"\"; }"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "lsp@alx99-personal": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Cooking"
    ]
  },
  "alwaysThinkingEnabled": true
}
