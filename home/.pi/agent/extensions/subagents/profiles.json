{
	"rootPolicy": {
		"maxConcurrentRootAgents": 4,
		"maxConcurrentDeepAgents": 1,
		"maxSpawnBudgetPerChild": 2
	},
	"profiles": {
		"fast": {
			"description": "Fast, economical work",
			"delegationEnabled": true,
			"countsTowardDeepAgentCap": false,
			"modelPriority": [
				{ "id": "openrouter/poolside/laguna-m.1:free", "defaultThinking": "high", "maxThinking": "high" },
				{ "id": "opencode-go/deepseek-v4-flash", "defaultThinking": "high", "maxThinking": "high" }
			]
		},
		"balanced": {
			"description": "Routine implementation and analysis with moderate cost",
			"delegationEnabled": true,
			"countsTowardDeepAgentCap": false,
			"modelPriority": [
				{ "id": "openai-codex/gpt-5.6-terra", "defaultThinking": "high", "maxThinking": "high" },
				{ "id": "opencode-go/glm-5.2", "defaultThinking": "high", "maxThinking": "high" }
			]
		},
		"deep-thinker": {
			"description": "Careful work for consequential tasks",
			"delegationEnabled": false,
			"countsTowardDeepAgentCap": true,
			"modelPriority": [{ "id": "openai-codex/gpt-5.6-sol", "defaultThinking": "high", "maxThinking": "xhigh" }]
		}
	},
	"agentPolicies": {
