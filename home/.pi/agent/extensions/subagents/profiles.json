				"maxLifetimeChildSpawns": 2,
				"allowedChildAgents": ["scout"],
				"allowedChildProfiles": ["fast"]
			}
		},
		"general": {
			"defaultProfile": "balanced",
			"allowedProfiles": ["fast", "balanced", "deep-thinker"],
			"delegation": {
				"mode": "grant-required",
				"maxLifetimeChildSpawns": 2,
				"allowedChildAgents": ["scout"],
				"allowedChildProfiles": ["fast"]
			}
		}
	}
}
