font-family = Departure Mono
font-size = 14

copy-on-select = clipboard
macos-option-as-alt = true
window-inherit-font-size = true
mouse-hide-while-typing = true

custom-shader = ~/.config/ghostty/cursor-blaze.glsl

# PS1 / LS_COLORS theme
# Mirrors the xterm-256 colors used in home/.bashrc and home/.profile:
# slate=245, red=203, green=114, yellow=179, blue=75, purple=141, cyan=109.
palette = 0=#1f1f28
palette = 1=#ff5f5f
palette = 2=#87d787
palette = 3=#d7af5f
palette = 4=#5fafff
palette = 5=#af87ff
palette = 6=#87afaf
palette = 7=#d7d7d7
palette = 8=#8a8a8a
palette = 9=#ff5f5f
palette = 10=#87d787
palette = 11=#d7af5f
palette = 12=#5f87ff
palette = 13=#af87ff
palette = 14=#87afaf
palette = 15=#ffffff
background = #1f1f28
foreground = #d7d7d7
cursor-color = #87afaf
selection-background = #3b3b44
selection-foreground = #d7d7d7
# background-opacity = 0.85
# background-blur = true

#keybind = ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard

# cmd+l -> ctrl+l
keybind = cmd+l=text:\x0c

# for claude code shift+enter
keybind = shift+enter=text:\x1b\r

# passthrough for tmux/shell
keybind = cmd+a=text:\x1ba
keybind = cmd+f=text:\x1bf
keybind = cmd+m=text:\x1bm
keybind = cmd+n=text:\x1bn
keybind = cmd+e=text:\x1be
keybind = cmd+i=text:\x1bi
keybind = cmd+g=text:\x1bg
keybind = cmd+t=text:\x1bt
keybind = cmd+h=text:\x1bh
keybind = cmd+o=text:\x1bo

confirm-close-surface = false
