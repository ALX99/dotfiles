background = #1F1F28
font-family = Departure Mono
font-size = 14

copy-on-select = clipboard
macos-option-as-alt = true
window-inherit-font-size = true
cursor-color = #33ccff
mouse-hide-while-typing = true

# https://base46.vercel.app/theme?name=radium&lang=rust&terminal=ghostty

#custom-shader = ~/dotfiles/misc/ghostty-shaders/bloom.glsl
#custom-shader = ~/dotfiles/misc/ghostty-shaders/dither.glsl
#custom-shader = ~/dotfiles/misc/ghostty-shaders/matrix-hallway.glsl
#custom-shader = ~/dotfiles/misc/ghostty-shaders/mnoise.glsl
#custom-shader = ~/dotfiles/misc/ghostty-shaders/retro-terminal.glsl
#custom-shader = ~/dotfiles/misc/ghostty-shaders/starfield-colors.glsl
custom-shader = ~/.config/ghostty/cursor-blaze.glsl

# gruvbox
palette = 0=#282828
palette = 1=#fb4934
palette = 2=#b8bb26
palette = 3=#fabd2f
palette = 4=#83a598
palette = 5=#d3869b
palette = 6=#8ec07c
palette = 7=#d5c4a1
palette = 8=#484442
palette = 9=#fb4934
palette = 10=#b8bb26
palette = 11=#fabd2f
palette = 12=#83a598
palette = 13=#d3869b
palette = 14=#8ec07c
palette = 15=#ebdbb2
background = #282828
foreground = #d5c4a1
cursor-color = #83a598
selection-background = #484442
selection-foreground = #d5c4a1
# background-opacity = 0.85
# background-blur = true

#keybind = ctrl+c=copy_to_clipboard
#keybind = ctrl+v=paste_from_clipboard

# cmd+l -> ctrl+l
keybind = cmd+l=text:\x0c

# for claude code shift+enter
keybind = shift+enter=text:\x1b\r

# passthrough for tmux/shell
keybind = cmd+a=text:\x1ba
keybind = cmd+f=text:\x1bf
keybind = cmd+m=text:\x1bm
keybind = cmd+n=text:\x1bn
keybind = cmd+e=text:\x1be
keybind = cmd+i=text:\x1bi
keybind = cmd+g=text:\x1bg
keybind = cmd+t=text:\x1bt
keybind = cmd+h=text:\x1bh
keybind = cmd+o=text:\x1bo

confirm-close-surface = false
