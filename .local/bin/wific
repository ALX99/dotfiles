#!/usr/bin/env bash
set -euo pipefail

# Linux-only: iwctl + fzf picker for device → network
[ "$(uname -s)" = "Linux" ] || { echo "wific: Linux only (uses iwctl)" >&2; exit 1; }
command -v iwctl >/dev/null 2>&1 || { echo "wific: iwctl not found" >&2; exit 1; }
command -v fzf >/dev/null 2>&1 || { echo "wific: fzf not found" >&2; exit 1; }

device="$(
  iwctl device list |
    sed 's/\x1b\[[0-9;]*m//g' |
    awk 'NR > 4 {print $1}' |
    grep . |
    fzf --prompt='device > ' --no-multi
)" || exit 0

[[ -z $device ]] && exit 0

iwctl station "$device" scan >/dev/null

network="$(
  iwctl station "$device" get-networks |
    sed 's/\x1b\[[0-9;]*m//g' |
    awk 'NR > 4 {sub(/^> /, ""); print $1}' |
    grep . |
    fzf --prompt='network > ' --no-multi
)" || exit 0

[[ -z $network ]] && exit 0

set -x
iwctl station "$device" connect "$network"
