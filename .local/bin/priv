#!/bin/sh
set -u

if [ "$(uname -s)" != "Linux" ]; then
  printf 'priv: Linux-only (requires /proc/sys and iptables)\n' >&2
  exit 0
fi

# Ignore all ICMP echo
printf '1\n' | sudo tee /proc/sys/net/ipv4/icmp_echo_ignore_all >/dev/null || exit 1

# NBnS
sudo iptables -A INPUT -p udp --destination-port 137 -j DROP
