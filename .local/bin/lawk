#!/bin/sh
arg=${1:-}
if [ -z "$arg" ] || [ "$arg" = "-" ]; then
  input=$(mktemp)
  trap 'rm -f "$input"' EXIT
  cat /dev/stdin >"$input"
else
  input=$arg
fi

echo '' |
  LAWK_INPUT=$input fzf --disabled \
    --preview-window='down:95%' \
    --print-query \
    --preview "gawk {q} \"\$LAWK_INPUT\""
