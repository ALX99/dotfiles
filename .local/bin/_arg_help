#!/usr/bin/env bash

set -euo pipefail

show_help() {
  if "$@" >/dev/null 2>&1; then
    if command -v bat >/dev/null 2>&1; then
      "$@" | bat --plain --language=help
    else
      "$@"
    fi
  else
    echo "failed: $*" >&2
    return 1
  fi
}

#shellcheck disable=SC2206
args=($READLINE_LINE)
((${#args[@]})) || exit 0

if bash -ic "alias ${args[0]}" &>/dev/null; then
  expanded="$(bash -ic "alias ${args[0]}" | sed "s/^alias [^=]*='//; s/'$//")"
  echo "Expanded alias: ${args[0]} -> $expanded"
  # shellcheck disable=SC2206
  args=($expanded)
fi

cmd=()
for arg in "${args[@]}"; do
  if [[ ! $arg =~ ^- ]]; then
    cmd+=("$arg")
  else
    break
  fi
done

while [ ${#cmd[@]} -gt 0 ]; do
  for help_flag in --help -h -? help usage; do
    if show_help "${cmd[@]}" "$help_flag" 2>/dev/null; then
      echo "${cmd[*]} $help_flag"
      exit 0
    fi
  done
  cmd=("${cmd[@]:0:${#cmd[@]}-1}")
done
