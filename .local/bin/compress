#!/usr/bin/env bash
# Compress directory

cLevel="3"
PARAMS=()
while (("$#")); do
  case "$1" in
  -cl | --compression-level)
    if ! [[ $2 =~ ^[0-9]+$ ]]; then
      echo "Error: compression level must be an integer 0-19, got '$2'" >&2
      exit 1
    fi
    cLevel=$2
    if (( cLevel < 0 || cLevel > 19 )); then
      echo "Error: compression level out of range, must be 0-19, got '$cLevel'" >&2
      exit 1
    fi
    shift 2
    ;;
  --) # end argument parsing
    shift
    break
    ;;
  -*) # unsupported flags
    echo "Error: Unsupported flag $1" >&2
    exit 1
    ;;
  *) # preserve positional arguments
    PARAMS+=("$1")
    shift
    ;;
  esac
done

tar -cvf archive.tar "${PARAMS[@]}" &&
  zstd -z --rm -"$cLevel" -T"$(nproc 2>/dev/null || sysctl -n hw.ncpu)" archive.tar -o archive.tar.zst
